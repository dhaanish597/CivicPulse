# Get a NVIDIA API key from build.nvidia.com
NVIDIA_API_KEY=

# Optional: create a Telegram bot token with @BotFather to enable polling intake
TELEGRAM_BOT_TOKEN=

# VITE_API_BASE_URL points to the backend (e.g. https://civicpulse-backend.onrender.com).
# Must be set in Vercel's project environment variables too.
VITE_API_BASE_URL=

# --- Round 2 Task 4: reliability hardening (server/index.mjs) ---------------

# Comma-separated list of exact production frontend origin(s) this backend's
# CORS should accept, e.g. https://civicpulse.vercel.app (no trailing slash).
# Multiple origins: https://civicpulse.vercel.app,https://civicpulse-admin.vercel.app
# Only used when NODE_ENV=production — in dev, CORS stays wide open ('*').
# Every https://*.vercel.app origin (preview deployments) is ALSO always
# accepted in production regardless of this value, since Vercel preview URLs
# are unpredictable per-branch/per-PR subdomains that can't be listed here in
# advance — see server/index.mjs#buildCorsOptions.
# Set this in Render's dashboard (render.yaml declares it `sync: false`,
# meaning Render will NOT set a value for you automatically).
ALLOWED_ORIGIN=

# Standard Node environment flag. Set to "production" on Render (render.yaml
# already does this) — it switches CORS to the ALLOWED_ORIGIN allowlist above
# instead of '*', and skips loading the Vite dev-middleware entirely. Leave
# unset (or "development") for local `npm run dev`.
NODE_ENV=

# Port the Express server listens on. Render provides this automatically at
# runtime — you do not need to set it there. Only useful to override locally
# if 5173 is already taken (server/index.mjs also auto-increments the port on
# EADDRINUSE when this is unset, so this is rarely needed even locally).
PORT=
