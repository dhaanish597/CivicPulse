# Get a NVIDIA API key from build.nvidia.com
NVIDIA_API_KEY=

# Optional: create a Telegram bot token with @BotFather to enable polling intake
TELEGRAM_BOT_TOKEN=

# VITE_API_BASE_URL points to the backend (e.g. https://civicpulse-backend.onrender.com).
# Must be set in Vercel's project environment variables too.
VITE_API_BASE_URL=
